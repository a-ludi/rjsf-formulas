{
  "name": "@a-ludi/rjsf-formulas",
  "version": "0.1.0",
  "description": "RJSF extension for computed fields driven by formulas",
  "author": "Arne Ludwig <arne.ludwig@posteo.de>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/a-ludi/rjsf-formulas.git"
  },
  "homepage": "https://a-ludi.github.io/rjsf-formulas/",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && cp dist/index.d.mts dist/index.d.cts",
    "build:docs": "typedoc && vitepress build website",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev": "vite --config demo/vite.config.ts",
    "test": "vitest run",
    "prepare": "husky",
    "prepublishOnly": "bun run build && bunx publint"
  },
  "peerDependencies": {
    "@rjsf/core": ">=5",
    "@rjsf/utils": ">=5",
    "react": ">=17"
  },
  "devDependencies": {
    "@rjsf/core": "^6",
    "@rjsf/utils": "^6",
    "@rjsf/validator-ajv8": "^6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18",
    "fast-deep-equal": "^3.1.3",
    "husky": "^9",
    "jsdom": "^29.1.1",
    "publint": "^0.3",
    "react": "^19",
    "rjsf-core-v5": "npm:@rjsf/core@^5",
    "rjsf-utils-v5": "npm:@rjsf/utils@^5",
    "rjsf-validator-v5": "npm:@rjsf/validator-ajv8@^5",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-dts": "^4",
    "vitepress": "^1.6.4",
    "vitest": "^3"
  },
  "dependencies": {
    "react-dom": "^19"
  }
}
