{
  "name": "rjsf-formulas",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && cp dist/index.d.mts dist/index.d.cts",
    "test": "vitest run",
    "prepare": "husky",
    "prepublishOnly": "bun run build && bunx publint"
  },
  "peerDependencies": {
    "@rjsf/core": ">=5",
    "@rjsf/utils": ">=5",
    "react": ">=17"
  },
  "devDependencies": {
    "@rjsf/core": "^6",
    "@rjsf/utils": "^6",
    "@rjsf/validator-ajv8": "^6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18",
    "fast-deep-equal": "^3.1.3",
    "husky": "^9",
    "publint": "^0.3",
    "react": "^18",
    "rjsf-core-v5": "npm:@rjsf/core@^5",
    "rjsf-utils-v5": "npm:@rjsf/utils@^5",
    "rjsf-validator-v5": "npm:@rjsf/validator-ajv8@^5",
    "typescript": "^5",
    "vite": "^6",
    "vite-plugin-dts": "^4",
    "vitest": "^3"
  }
}
